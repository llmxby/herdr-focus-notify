# Set to 0/false/no/off to disable notifications without unlinking the plugin.
HERDR_FOCUS_NOTIFY_ENABLED=1

# Override if terminal-notifier is installed somewhere non-standard.
# HERDR_FOCUS_NOTIFY_NOTIFIER=/opt/homebrew/bin/terminal-notifier

# Comma-separated statuses to notify for. Defaults to blocked,done.
# HERDR_FOCUS_NOTIFY_STATUSES=blocked,done

# Print extra diagnostic output to Herdr plugin logs.
# HERDR_FOCUS_NOTIFY_DEBUG=1

